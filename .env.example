# =============================================================================
# AI Quant Agent v3.0 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# 所有变量前缀 QUANT_，详见 src/quant_agent/config.py
# =============================================================================

# ── 数据源 (必填至少一项) ──────────────────────────────────────────────────────
QUANT_TUSHARE_TOKEN=             # Tushare API token (https://tushare.pro)
# TUSHARE_TOKEN=                 # 兼容旧写法

# ── LLM (可选，未来 Agent 使用) ───────────────────────────────────────────────
# QUANT_OPENAI_API_KEY=          # OpenAI API key
# QUANT_OPENAI_MODEL=gpt-4o      # LLM 模型
# QUANT_ZHIPU_API_KEY=           # 智谱 API key
# QUANT_ZHIPU_MODEL=glm-4        # 智谱模型

# ── 存储 ─────────────────────────────────────────────────────────────────────
# QUANT_DATA_DIR=data/cache      # 数据缓存目录
# QUANT_PARQUET_DIR=data/parquet # Parquet 存储目录

# ── 风控参数 ─────────────────────────────────────────────────────────────────
# QUANT_MAX_POSITION_PCT=0.20    # 单只仓位上限 (20%)
# QUANT_MAX_PORTFOLIO_RISK=0.80  # 组合最大风险敞口 (80%)
# QUANT_DEFAULT_STOP_LOSS=-0.08  # 止损线 (-8%)
# QUANT_DEFAULT_TAKE_PROFIT_1=0.10  # 止盈线1 (+10%)
# QUANT_DEFAULT_TAKE_PROFIT_2=0.20  # 止盈线2 (+20%)

# ── 回测参数 ─────────────────────────────────────────────────────────────────
# QUANT_COMMISSION_RATE=0.0003   # 佣金费率 (万三)
# QUANT_STAMP_TAX_RATE=0.001     # 印花税率 (千一，仅卖出)
# QUANT_SLIPPAGE_BPS=1.0         # 滑点 (基点)

# ── 并发 ─────────────────────────────────────────────────────────────────────
# QUANT_FETCH_MAX_WORKERS=5      # 批量获取并发线程数 (1=顺序执行)

# ── 数据库 (预留) ─────────────────────────────────────────────────────────────
# QUANT_POSTGRES_URL=postgresql://localhost/quant
# QUANT_REDIS_URL=redis://localhost:6379/0

# ── 日志 ─────────────────────────────────────────────────────────────────────
# QUANT_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ── 邮件通知 ─────────────────────────────────────────────────────────────────
# QUANT_EMAIL_ENABLED=false      # 启用邮件通知
# QUANT_EMAIL_SMTP_SERVER=smtp.163.com  # SMTP 服务器
# QUANT_EMAIL_SMTP_PORT=465      # SMTP 端口 (SSL)
# QUANT_EMAIL_SENDER=            # 发件邮箱
# QUANT_EMAIL_PASSWORD=          # SMTP 授权码 (非邮箱密码)
# QUANT_EMAIL_RECIPIENTS=        # 收件人，逗号分隔
