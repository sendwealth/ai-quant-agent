# TuShare API Token（免费）
# 获取地址: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# Email Alert Configuration
# 邮箱告警配置（用于数据更新失败、数据过期等告警）

# SMTP 服务器（以163邮箱为例）
EMAIL_SMTP_SERVER=smtp.163.com

# SMTP 端口（SSL通常是465）
EMAIL_SMTP_PORT=465

# 发送者邮箱
EMAIL_SENDER=your_email@163.com

# 邮箱授权码（不是密码！）
# 获取方式: 登录163邮箱 → 设置 → POP3/SMTP/IMAP → 开启服务 → 获取授权码
EMAIL_PASSWORD=your_email_auth_code_here

# 收件人邮箱（多个用逗号分隔）
EMAIL_RECIPIENTS=alert@163.com
